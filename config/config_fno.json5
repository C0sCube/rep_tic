  "REGEX":{
    "FUTURE":"^[A-Z0-9]+([FGHJKMNQUVXZ])[0-9]+\\.NSF$",
    "OPTION":"^[A-Z0-9]+[CP][0-9]+\\.NSF$",
    "SPREAD":"^[A-Z0-9]+[A-Z]{3}\\d{2}[A-Z]{3}\\d{2}\\.NSF$",
    "JUNK":"",

    "OPT_FEED":"^([A-Z0-9]+)(\\d{6})([CP])(\\d+)\\.NSF$",  // STOCK,DATE,(CALL/PUT),VALUE
    "FUT_FEED":"^([A-Z0-9]+)([FGHKMNQUVXZ])(\\d{2})\\.NSF$", // STOCK,MONTH,YEAR
    "SPR_FEED":"^([A-Z0-9]+)([A-Z]{3}\\d{2}[A-Z]{3}\\d{2})\\.NSF$"
  },
